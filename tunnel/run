#!/usr/bin/env bash
# Committed bootstrap wrapper — this is the ONE file every teammate needs to
# know about. It makes sure cloudflared + the shared `tunnel` engine exist on
# this machine (installing whichever is missing, the first time anyone runs
# it), keeps the installed engine in sync if the committed one in the repo
# has since changed, then delegates straight to it. All of this is a fast
# no-op once everything's current.
#
# Usage (from the project root, after `git pull`):
#   ./tunnel/run start
#   ./tunnel/run restart
#   ./tunnel/run stop
#
# Requires this whole `tunnel/` folder to be committed in the repo (not just
# `.tunnel.config.sh`) — `run` copies its sibling `engine/tunnel` file.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ENGINE_SRC="$SCRIPT_DIR/engine/tunnel"
ENGINE_DEST="$HOME/.local/bin/tunnel"

ensure_cloudflared() {
  command -v cloudflared > /dev/null 2>&1 && return
  echo "→ cloudflared not found — this is what actually creates the public tunnel."
  if command -v brew > /dev/null 2>&1; then
    echo "  Installing it via Homebrew (brew install cloudflared)..."
    brew install cloudflared
  else
    echo "  Homebrew isn't available to install it automatically. Install it yourself:"
    echo "    https://developers.cloudflare.com/cloudflare-one/connections/connect-networks/downloads/"
    exit 1
  fi
}

ensure_python3() {
  command -v python3 > /dev/null 2>&1 && return
  echo "→ python3 not found. It ships with macOS by default; on Linux, install it via your"
  echo "  distro's package manager (e.g. apt install python3) and try again."
  exit 1
}

ensure_cloudflared
ensure_python3

# Copies $ENGINE_SRC into place atomically — via a temp file in the same
# directory + `mv`, not a direct `cp` onto $ENGINE_DEST. A plain `cp` can be
# observed mid-write by a concurrent `tunnel/run` invocation (e.g. two
# terminals both running it right as the engine changes), which could see a
# truncated/partial file and fail. `mv` within the same filesystem is atomic,
# so any concurrent reader always sees either the old file or the new one,
# never a partial write.
install_engine() {
  local tmp
  tmp="$(mktemp "$HOME/.local/bin/tunnel.XXXXXX")"
  cp "$ENGINE_SRC" "$tmp"
  chmod +x "$tmp"
  mv "$tmp" "$ENGINE_DEST"
}

mkdir -p "$HOME/.local/bin"

# Install if missing, or re-sync if the committed engine has changed since it
# was last installed — otherwise `run` only ever installs once, and silently
# keeps using a stale copy forever even after the repo's engine is updated
# (confirmed happening in practice: a fix landed in tunnel/engine/tunnel on
# `dev`, a teammate pulled it, but their already-installed ~/.local/bin/tunnel
# stayed on the old copy since nothing had ever re-synced it). Also repairs
# the executable bit even when the contents already match — an installed
# copy that's identical byte-for-byte but somehow lost +x (e.g. a backup/sync
# tool stripped permissions) would otherwise never get chmod'd, and silently
# fail with "permission denied" on the next exec.
if [ ! -f "$ENGINE_DEST" ]; then
  echo "→ tunnel engine not found — installing to $ENGINE_DEST"
  install_engine
elif ! cmp -s "$ENGINE_SRC" "$ENGINE_DEST" || [ ! -x "$ENGINE_DEST" ]; then
  echo "→ installed tunnel engine is out of date — updating $ENGINE_DEST"
  install_engine
fi

case ":$PATH:" in
  *":$HOME/.local/bin:"*) ;;
  *)
    echo "→ ~/.local/bin isn't on your PATH yet."
    echo "  Add this to your shell profile (~/.zshrc or ~/.bashrc), then open a new terminal:"
    echo "    export PATH=\"\$HOME/.local/bin:\$PATH\""
    echo "  Running it directly for this one invocation instead:"
    exec "$ENGINE_DEST" "$@"
    ;;
esac

exec tunnel "$@"
