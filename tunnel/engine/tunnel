#!/usr/bin/env bash
# tunnel — generic multi-service local-dev + Cloudflare-tunnel orchestrator.
#
# This script has ZERO project-specific knowledge. Everything project-specific
# (which services exist, how to build/start them, what to do once tunnel URLs
# are known) lives in a per-project config file, found in this order:
#   1. $TUNNEL_CONFIG (explicit path)
#   2. ./.tunnel.config.sh   (in the directory you run `tunnel` from)
#   3. ~/.config/tunnel/<basename of that directory>.sh
#
# Usage:
#   tunnel start      # stop everything, start all services + tunnels, run post-hook
#   tunnel restart     # same as start
#   tunnel stop        # stop all services + tunnels
#
# ---- Config file contract -------------------------------------------------
#
#   SERVICES=(name1 name2 ...)             # order matters — started in this order
#
#   For each name in SERVICES, define:
#     <name>_port=NNNN                     # required — port the service listens on
#     <name>_start_cmd="..."               # required — command to start it
#     <name>_build_cmd="..."               # optional — run once before starting
#     <name>_ready_pattern="regex"          # optional — grep pattern in its log
#                                           #   signaling "ready" (else just waits
#                                           #   for the port to open)
#     <name>_kill_pattern="pattern"         # optional — extra `pkill -f` pattern
#                                           #   used on stop/restart (besides the
#                                           #   port-based kill, which always runs)
#     <name>_tunnel_provider="ngrok"        # optional — default is "cloudflared"
#                                           #   (free, but its URL changes every run).
#                                           #   Set to "ngrok" for a persistent free
#                                           #   static domain instead (one per ngrok
#                                           #   account) — requires <name>_ngrok_domain
#                                           #   and `ngrok config add-authtoken` already
#                                           #   run once on this machine.
#     <name>_ngrok_domain="foo.ngrok-free.app"  # required if tunnel_provider=ngrok
#
#   Optional hook, called once after every service is running and tunneled:
#     post_tunnel_hook() { ... }
#
#   Inside the config and the hook, these are available:
#     $TUNNEL_PROJECT_DIR                  # the directory `tunnel` was run from
#     $TUNNEL_URL_<NAME>                   # public tunnel URL for each service
#                                           #   (NAME uppercased, non-alnum -> _)
#   And these helper functions:
#     run_build <name>                     # (re)run <name>_build_cmd if set
#     restart_service <name>                # kill + restart <name> (tunnel untouched)
#
# -----------------------------------------------------------------------------

set -uo pipefail

TUNNEL_PROJECT_DIR="$(pwd)"
export TUNNEL_PROJECT_DIR

find_config() {
  if [ -n "${TUNNEL_CONFIG:-}" ]; then
    echo "$TUNNEL_CONFIG"
    return
  fi
  if [ -f "$TUNNEL_PROJECT_DIR/.tunnel.config.sh" ]; then
    echo "$TUNNEL_PROJECT_DIR/.tunnel.config.sh"
    return
  fi
  local by_name="$HOME/.config/tunnel/$(basename "$TUNNEL_PROJECT_DIR").sh"
  if [ -f "$by_name" ]; then
    echo "$by_name"
    return
  fi
  echo ""
}

CONFIG_FILE="$(find_config)"
if [ -z "$CONFIG_FILE" ]; then
  cat >&2 <<EOF
No tunnel config found for this directory ($TUNNEL_PROJECT_DIR).

Looked for, in order:
  \$TUNNEL_CONFIG
  ./.tunnel.config.sh
  ~/.config/tunnel/$(basename "$TUNNEL_PROJECT_DIR").sh

Create one of those (see the header of $0 for the config contract) and try again.
EOF
  exit 1
fi

LOG_DIR="$TUNNEL_PROJECT_DIR/.tunnel/logs"
mkdir -p "$LOG_DIR"

ensure_gitignored() {
  # Make sure .tunnel/ (logs) and config.tunnel (personal overrides — see
  # below) never end up staged/committed by accident.
  local gitignore="$TUNNEL_PROJECT_DIR/.gitignore"
  if [ -d "$TUNNEL_PROJECT_DIR/.git" ]; then
    for entry in ".tunnel/" "config.tunnel"; do
      if ! grep -qxF "$entry" "$gitignore" 2>/dev/null; then
        { [ -f "$gitignore" ] && [ -s "$gitignore" ] && echo ""; echo "$entry"; } >> "$gitignore"
      fi
    done
  fi
}
ensure_gitignored

ensure_config_tunnel_template() {
  # Create a blank, commented-out config.tunnel the first time it's missing,
  # so a person opts into a persistent ngrok domain by just uncommenting +
  # filling in one line, instead of having to know this file's shape at all.
  local config_tunnel="$TUNNEL_PROJECT_DIR/config.tunnel"
  if [ ! -f "$config_tunnel" ]; then
    cat > "$config_tunnel" <<'TEMPLATE'
# Put your free ngrok static domain here and use that every time you tunnel.
# Leave it unset (or delete this file) and you'll fall back to a random
# cloudflared URL that changes on every `tunnel start`.

# NGROK_DOMAIN="your-name.ngrok-free.app"
TEMPLATE
  fi
}
ensure_config_tunnel_template

log() { echo "→ $*"; }

# Optional personal override file, sourced BEFORE the shared committed
# config so anything the config checks for (e.g. "$NGROK_DOMAIN" being set)
# sees it in time. This is where your own ngrok static domain goes — that's
# personal to your account and has no business in a file the whole team
# shares. Never committed (see ensure_gitignored above). One line is enough:
#   NGROK_DOMAIN="your-name.ngrok-free.app"
# What that variable actually does is up to the project's own
# .tunnel.config.sh to decide (see examples/web-and-backend.sh) — the engine
# itself doesn't know or care what NGROK_DOMAIN means, it just makes sure
# this file, if present, gets sourced first.
LOCAL_OVERRIDE="$TUNNEL_PROJECT_DIR/config.tunnel"
if [ -f "$LOCAL_OVERRIDE" ]; then
  # shellcheck disable=SC1090
  source "$LOCAL_OVERRIDE"
fi

# shellcheck disable=SC1090
source "$CONFIG_FILE"

if [ "${#SERVICES[@]:-0}" -eq 0 ]; then
  echo "Config $CONFIG_FILE defines no SERVICES array." >&2
  exit 1
fi

# Convenience defaults for the common two-service "web" + "bff" shape — only
# applied when a service is literally named "web" or "bff" and its config
# didn't set <name>_port itself. Any other service name always requires an
# explicit port.
for name in "${SERVICES[@]}"; do
  port_var="${name}_port"
  if [ -z "${!port_var:-}" ]; then
    case "$name" in
      web) export "$port_var=3000" ;;
      bff) export "$port_var=4000" ;;
      *)
        echo "Service '$name' has no ${name}_port set in $CONFIG_FILE (only 'web'/'bff' get a default)." >&2
        exit 1
        ;;
    esac
  fi
done

kill_port() {
  local port="$1"
  local pids
  pids="$(lsof -ti "tcp:$port" -sTCP:LISTEN 2>/dev/null || true)"
  if [ -n "$pids" ]; then
    kill -9 $pids 2>/dev/null || true
  fi
}

kill_service() {
  local name="$1"
  local port_var="${name}_port"
  local kill_pattern_var="${name}_kill_pattern"
  local pattern="${!kill_pattern_var:-}"
  if [ -n "$pattern" ]; then
    pkill -f "$pattern" 2>/dev/null || true
  fi
  kill_port "${!port_var}"
}

tunnel_provider_for() {
  local name="$1"
  local provider_var="${name}_tunnel_provider"
  echo "${!provider_var:-cloudflared}"
}

kill_tunnel_for() {
  local name="$1"
  local port_var="${name}_port"
  local port="${!port_var}"
  if [ "$(tunnel_provider_for "$name")" = "ngrok" ]; then
    pkill -f "ngrok http .* $port( |$)" 2>/dev/null || true
  else
    pkill -f "cloudflared tunnel --url http://localhost:$port" 2>/dev/null || true
  fi
}

wait_for_port() {
  local port="$1" timeout="${2:-30}" waited=0
  while ! lsof -i "tcp:$port" -sTCP:LISTEN >/dev/null 2>&1; do
    sleep 0.5
    waited=$((waited + 1))
    if [ "$waited" -ge $((timeout * 2)) ]; then
      echo "Timed out waiting for port $port to open" >&2
      return 1
    fi
  done
}

wait_for_log_pattern() {
  local file="$1" pattern="$2" timeout="${3:-30}" waited=0
  while ! grep -qE "$pattern" "$file" 2>/dev/null; do
    sleep 0.5
    waited=$((waited + 1))
    if [ "$waited" -ge $((timeout * 2)) ]; then
      echo "Timed out waiting for '$pattern' in $file" >&2
      tail -30 "$file" >&2 || true
      return 1
    fi
  done
}

extract_tunnel_url() {
  grep -oE "https://[a-z0-9-]+\.trycloudflare\.com" "$1" 2>/dev/null | head -1
}

env_name_for() {
  # e.g. "web" -> TUNNEL_URL_WEB, "my-service" -> TUNNEL_URL_MY_SERVICE
  echo "TUNNEL_URL_$(echo "$1" | tr '[:lower:]-' '[:upper:]_')"
}

# Many CLIs/loggers colorize their output with ANSI escape codes when they
# detect a terminal — great to watch live, unreadable garbage when it ends
# up as raw bytes in a log file opened in an editor. Strip them so log files
# are always clean plain text. `-l`/`-u` keep sed itself line-buffered
# (BSD sed on macOS vs GNU sed elsewhere) so this doesn't reintroduce the
# bursty-output problem `run_with_pty` exists to fix.
strip_ansi() {
  local esc
  esc="$(printf '\033')"
  if [ "$(uname)" = "Darwin" ]; then
    sed -l -E "s/${esc}\[[0-9;]*[a-zA-Z]//g"
  else
    sed -u -E "s/${esc}\[[0-9;]*[a-zA-Z]//g"
  fi
}

run_build() {
  local name="$1"
  local build_var="${name}_build_cmd"
  local cmd="${!build_var:-}"
  if [ -n "$cmd" ]; then
    log "Building $name"
    # pipefail (set at the top of this script) means this correctly reflects
    # a failure in $cmd itself, not just strip_ansi — without checking it,
    # a real build failure (compile error, missing env var, whatever) got
    # silently swallowed and the script went on to start_service anyway,
    # launching the real start command against a missing/broken build
    # (e.g. `next start` erroring "Could not find a production build" —
    # confirmed happening in practice on a teammate's machine).
    if ! eval "$cmd" 2>&1 | strip_ansi > "$LOG_DIR/$name.build.log"; then
      echo "✗ Build failed for $name — see $LOG_DIR/$name.build.log for the real error." >&2
      echo "  Please fix your build, then run \`tunnel start\` again — nothing will start" >&2
      echo "  or tunnel until $name builds successfully." >&2
      exit 1
    fi
  fi
}

# Most runtimes (Node/Bun included) switch stdout to fully-buffered (instead
# of line-buffered) the moment it's not a real terminal — which is exactly
# what happens when we redirect it into a log file. That makes log lines
# show up in bursts instead of as they're actually emitted. Faking a
# pseudo-tty via `script` tricks the isatty() check into staying
# line-buffered, so log-tailing (and wait_for_log_pattern) reflects reality.
run_with_pty() {
  local cmd="$1"
  # `script` needs a real controlling terminal to copy termios settings from
  # (fails outright with "tcgetattr/ioctl: Operation not supported" otherwise
  # — e.g. run from CI, a non-interactive script, or certain sandboxes).
  # Fall back to plain execution there; the only cost is losing the
  # line-buffering fix in that specific case, not a hard failure.
  #
  # IMPORTANT: `script`'s own stdin — not the pty it creates for the child —
  # is what it puts into raw mode, to transparently relay real keystrokes.
  # We run it backgrounded with no interactive input to relay, so that raw
  # mode serves no purpose here — and if this process gets killed forcefully
  # (which `kill_service` always does, via `kill -9`, on every restart),
  # `script` never gets a chance to restore the terminal afterward, leaving
  # the actual calling terminal permanently stuck in raw mode (symptom:
  # output starts "staircasing" — no more automatic return-to-column-0 on
  # newline — until the terminal is closed or `stty sane` is run manually).
  # Redirecting script's own stdin to /dev/null stops it from touching the
  # real terminal's settings at all — the child still gets a proper pty
  # (line-buffering intact), script just never has real keystrokes to relay.
  if [ -t 0 ] && command -v script > /dev/null 2>&1; then
    if [ "$(uname)" = "Darwin" ]; then
      script -q /dev/null bash -c "$cmd" < /dev/null
      return
    else
      script -qc "$cmd" /dev/null < /dev/null
      return
    fi
  fi
  eval "$cmd"
}

start_service() {
  local name="$1"
  local start_var="${name}_start_cmd" port_var="${name}_port" ready_var="${name}_ready_pattern"
  local cmd="${!start_var}" port="${!port_var}" ready="${!ready_var:-}"
  log "Starting $name on :$port"
  : > "$LOG_DIR/$name.log"
  run_with_pty "$cmd" 2>&1 | strip_ansi > "$LOG_DIR/$name.log" &
  if [ -n "$ready" ]; then
    wait_for_log_pattern "$LOG_DIR/$name.log" "$ready" 30 || exit 1
  else
    wait_for_port "$port" 30 || exit 1
  fi
}

restart_service() {
  local name="$1"
  log "Restarting $name"
  kill_service "$name"
  sleep 1
  start_service "$name"
}

tunnel_service() {
  local name="$1"
  local port_var="${name}_port"
  local port="${!port_var}"
  local cf_log="$LOG_DIR/$name.tunnel.log"
  local provider
  provider="$(tunnel_provider_for "$name")"
  log "Opening tunnel for $name (:$port) via $provider"
  : > "$cf_log"

  local url
  if [ "$provider" = "ngrok" ]; then
    local domain_var="${name}_ngrok_domain"
    local domain="${!domain_var:-}"
    if [ -z "$domain" ]; then
      echo "Service '$name' has ${name}_tunnel_provider=ngrok but no ${name}_ngrok_domain set." >&2
      exit 1
    fi
    ngrok http --url="$domain" "$port" --log=stdout > "$cf_log" 2>&1 &
    wait_for_log_pattern "$cf_log" "started tunnel" 20 || exit 1
    url="https://$domain"
  else
    cloudflared tunnel --url "http://localhost:$port" > "$cf_log" 2>&1 &
    wait_for_log_pattern "$cf_log" "https://[a-z0-9-]+\.trycloudflare\.com" 20 || exit 1
    url="$(extract_tunnel_url "$cf_log")"
  fi

  local var_name
  var_name="$(env_name_for "$name")"
  export "$var_name=$url"
  log "$name tunnel: $url"
}

do_stop() {
  log "Stopping all services and tunnels"
  for name in "${SERVICES[@]}"; do
    kill_service "$name"
    kill_tunnel_for "$name"
  done
}

tunnel_already_up() {
  local name="$1"
  local port_var="${name}_port"
  local port="${!port_var}"
  if [ "$(tunnel_provider_for "$name")" = "ngrok" ]; then
    pgrep -f "ngrok http .*$port" > /dev/null 2>&1
  else
    pgrep -f "cloudflared tunnel --url http://localhost:$port" > /dev/null 2>&1
  fi
}

service_already_up() {
  # A port being open isn't enough — a wedged/hung process can keep holding
  # it open while never actually responding to a new request (this happened
  # in practice: a stuck in-flight request left a Next.js server accepting
  # connections but answering nothing). Confirm it actually responds before
  # calling it "up" — otherwise `tunnel start`'s idempotency check would
  # wrongly report "already running" on something silently broken, instead
  # of catching and fixing it with a real restart.
  local name="$1"
  local port_var="${name}_port"
  local port="${!port_var}"
  lsof -i "tcp:$port" -sTCP:LISTEN > /dev/null 2>&1 || return 1
  curl -s -o /dev/null --max-time 5 "http://localhost:$port/" > /dev/null 2>&1
}

everything_already_up() {
  for name in "${SERVICES[@]}"; do
    service_already_up "$name" || return 1
    tunnel_already_up "$name" || return 1
  done
  return 0
}

recover_urls_or_return_1() {
  # Populates TUNNEL_URL_<NAME> for each service — from its known static
  # domain (ngrok) or from its existing tunnel log (cloudflared). Returns 1
  # (without partial exports the caller should rely on) if any single one
  # can't be recovered.
  for name in "${SERVICES[@]}"; do
    local url
    if [ "$(tunnel_provider_for "$name")" = "ngrok" ]; then
      local domain_var="${name}_ngrok_domain"
      url="https://${!domain_var:-}"
      [ "$url" = "https://" ] && url=""
    else
      local cf_log="$LOG_DIR/$name.tunnel.log"
      url="$(extract_tunnel_url "$cf_log")"
    fi
    if [ -z "$url" ]; then
      return 1
    fi
    export "$(env_name_for "$name")=$url"
  done
  return 0
}

print_summary() {
  echo ""
  echo "=================================================="
  for name in "${SERVICES[@]}"; do
    var_name="$(env_name_for "$name")"
    echo " $name: ${!var_name}"
  done
  echo "=================================================="
  echo "Logs: $LOG_DIR"
}

do_start() {
  if everything_already_up && recover_urls_or_return_1; then
    log "Everything's already running — not restarting anything"
    print_summary
    echo ""
    echo "(Nothing was stopped or rebuilt. Use \`tunnel restart\` to restart the servers behind"
    echo " these same links, or \`tunnel stop\` first if you want a genuinely fresh start.)"
    return
  fi

  do_stop
  sleep 1

  for name in "${SERVICES[@]}"; do
    run_build "$name"
    start_service "$name"
    tunnel_service "$name"
  done

  if declare -f post_tunnel_hook > /dev/null; then
    log "Running post_tunnel_hook"
    post_tunnel_hook
  fi

  print_summary
}

do_restart() {
  # Restart the servers but keep existing tunnels alive (same public URLs) —
  # falls back to a full `start` if any tunnel isn't already running.
  for name in "${SERVICES[@]}"; do
    if ! tunnel_already_up "$name"; then
      log "No existing tunnel for $name — doing a full start instead"
      do_start
      return
    fi
  done

  if ! recover_urls_or_return_1; then
    log "Couldn't recover an existing tunnel URL — doing a full start instead"
    do_start
    return
  fi

  for name in "${SERVICES[@]}"; do
    run_build "$name"
    restart_service "$name"
  done

  if declare -f post_tunnel_hook > /dev/null; then
    log "Running post_tunnel_hook"
    post_tunnel_hook
  fi

  print_summary
}

case "${1:-}" in
  start)
    do_start
    ;;
  restart)
    do_restart
    ;;
  stop)
    do_stop
    log "Stopped."
    ;;
  *)
    echo "Usage: tunnel {start|restart|stop}" >&2
    exit 1
    ;;
esac
